---
// Mirrors web/src/components/sidebar.tsx .brand markup:
// glowing amber dot + "transcoder" + amber "/r".
interface Props {
  size?: 'md' | 'lg' | 'xl';
}
const { size = 'md' } = Astro.props;
const sizes = {
  md: { text: 'text-lg', dot: 'w-2 h-2',   gap: 'gap-2' },
  lg: { text: 'text-3xl', dot: 'w-3 h-3', gap: 'gap-3' },
  xl: { text: 'text-5xl sm:text-6xl', dot: 'w-4 h-4 sm:w-5 sm:h-5', gap: 'gap-3 sm:gap-4' },
};
const s = sizes[size];
---
<span class={`inline-flex items-center select-none font-mono font-bold tracking-tight ${s.gap}`}>
  <span
    class={`inline-block rounded-full bg-accent ${s.dot}`}
    style="box-shadow: 0 0 12px #ffb62755;"
    aria-hidden="true"
  ></span>
  <span class={s.text}>transcoder<span class="text-accent">/r</span></span>
</span>
